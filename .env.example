# PortSyncro Environment Variables Template
# Copy this file to .env.local for local development
# For production (Vercel), set these in Vercel Dashboard

# ========================================
# FIREBASE CONFIGURATION (Public - NEXT_PUBLIC_ prefix)
# Get these from: Firebase Console > Project Settings > Your Apps
# ========================================
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ========================================
# DEMO ACCOUNT (Optional)
# If set, enables "Login with Demo Account" button
# ========================================
NEXT_PUBLIC_DEMO_EMAIL=demo@example.com
NEXT_PUBLIC_DEMO_PASSWORD=your_demo_password

# ========================================
# ENCRYPTION KEY (Server-side only - NO NEXT_PUBLIC_ prefix)
# CRITICAL: Must be exactly 64 characters (hex string = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ========================================
ENCRYPTION_KEY=generate_your_own_64_character_hex_string_here

# ========================================
# DEVELOPMENT ONLY (Optional)
# ========================================
NEXT_TELEMETRY_DISABLED=1

# ========================================
# COINGECKO API KEY (Optional - Server-side only)
# Set to use your CoinGecko Demo/Pro API key to bypass rate limits
# ========================================
COINGECKO_API_KEY=your_coingecko_api_key_here
COINGECKO_PRO_API=false
